# =============================================
# Perpolis — environment variables
# Copy this file to .env.local and fill in your values.
# =============================================

# --- Database (Postgres) -----------------------------------------------------
# Any standard Postgres connection string works.
# Recommended: Neon (https://neon.tech) for serverless.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# --- Solana network ----------------------------------------------------------
# Primary RPC endpoint used by server routes. A dedicated provider key is
# strongly recommended in production (public mainnet-beta is rate-limited).
SOLANA_RPC_PRIMARY="https://api.mainnet-beta.solana.com"
SOLANA_RPC_FALLBACK="https://api.mainnet-beta.solana.com"

# Client-side RPC (must be a public read-only endpoint).
NEXT_PUBLIC_SOLANA_RPC="https://api.mainnet-beta.solana.com"

# Helius v0 balances API key (optional — used only by /api/wallet-balance).
# Get one at https://helius.xyz
HELIUS_API_KEY=""

# --- Token mints -------------------------------------------------------------
# USDC mainnet
USDC_MINT="EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
NEXT_PUBLIC_USDC_MINT="EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"

# USDT mainnet
USDT_MINT="Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB"
NEXT_PUBLIC_USDT_MINT="Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB"

# --- Treasury / payments -----------------------------------------------------
# Server address that receives demo-deposit payments.
PAYMENT_ADDRESS=""

# Public copy of treasury, used by the deposit UI.
NEXT_PUBLIC_TREASURY_WALLET=""
NEXT_PUBLIC_PAYMENT_ADDRESS=""

# Minimum USD to credit a deposit.
MIN_DEPOSIT_USD="0.85"

# Demo USDC credited per real-USDC deposit.
DEVNET_CREDIT_USD="1000"

# --- Market data -------------------------------------------------------------
# Birdeye public API key for OHLCV and search.
BIRDEYE_API_KEY=""
